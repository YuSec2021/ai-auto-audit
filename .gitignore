# ============================================================
# ai-auto-audit — Root .gitignore
# Hard rules:
#   - ALL Excel files are ignored (per project policy 2026-06-10)
#   - The 3 previously-tracked xlsx files are untracked via
#     `git rm --cached` in the same commit that adds this .gitignore
#   - Hidden runtime / tool directories (commit-agnostic):
#     .sprintfoundry/ SprintFoundry three-agent harness state
#     .claude/        Claude Code session/tooling (skills live in
#                     user install, not in this repo)
#     .playwright-mcp/ Playwright MCP server capture artifacts
# ============================================================

# --- Excel / spreadsheet (project policy: ignore all) ---
*.xlsx
*.xls
*.xlsb
*.xlsm
*.xltx
*.xltm
*.csv

# --- Images (project policy 2026-06-10: ignore all PNGs) ---
*.png

# --- Build / runtime artifacts ---
node_modules/
dist/
build/
out/
coverage/
*.tsbuildinfo

# --- Logs (project + tooling) ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Test / e2e artifacts ---
playwright-report/
test-results/
.screenshots/
.playwright-mcp/
playwright-debug.png

# --- Environment / secrets ---
.env
.env.local
.env.*.local

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# --- Hidden runtime / tool directories (added 2026-06-10) ---
.sprintfoundry/
.claude/

# --- Raw data samples (not source code) ---
5-9/
异常SKU*/
已审核*/
未审核*/
待审核_split/
*_combined_output.xlsx
*_output.xlsx
*_output.js
*_split/

# --- Spec-Kit scaffold (deleted 2026-06-10) ---
.specify/
specs/

# --- Misc project noise ---
.vite/
.cache/
.tmp/
tmp/


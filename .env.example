# =============================================================================
# AI 自动商品审核 — 环境变量模板 (committed, no real values)
#
# 复制为 .env 并填入真实值:
#   cp .env.example .env
#
# .env 已被 .gitignore 屏蔽；本文件是给协作者/新成员看的"契约"。
# 真实凭证轮换流程见 ../../SECURITY.md
# =============================================================================

# -------- 京东 VOP 开放平台 --------
# 申请: https://open.jd.com  →  应用管理 → 应用详情
JD_HOST="https://api.jd.com/routerjson"
JD_APP_KEY="your-jd-app-key"
JD_APP_SECRET="your-jd-app-secret"

# -------- 内部 JD 价格 API --------
# 由运维在 VPN/内网提供。例: http://192.168.x.x:12122
JD_PRICE_API_BASE="http://your-internal-jd-price-host:port"

# -------- DashScope (阿里云通义千问) --------
# 申请: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY="sk-your-dashscope-api-key"

# -------- 阿里云 PolarDB (PostgreSQL) --------
# 申请: 通过运维开库
POSTGRES_URL="postgresql://user:password@host:port/database"

# -------- 企业微信群机器人 Webhook --------
# 创建: 群 → 群机器人 → 添加 → 复制 Webhook URL
WECOM_WEBHOOK_URL="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key"

# -------- 内部搜索服务 (SH_BASE) --------
# 由内部搜索服务团队提供
SH_BASE="http://your-search-server/api/searchWithDetail"
SH_API_KEY="your-search-api-key"

# -------- 内网 MongoDB --------
# 由运维开库 (内网 IP)
MONGO_DSN="mongodb://user:password@internal-host:port"

# -------- 内网 Qdrant 向量库 --------
# 由运维部署 (内网 IP)
QDRANT_URL="http://internal-qdrant-host:port/collections/your-collection/points/query"
QDRANT_API_KEY="your-qdrant-api-key"
